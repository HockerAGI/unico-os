# =========================================================
# UnicOs — Environment Variables (.env.example)
# =========================================================

# Supabase (cliente / navegador)
NEXT_PUBLIC_SUPABASE_URL=https://lpbzndnavkbpxwnlbqgb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (servidor)
SUPABASE_URL=https://lpbzndnavkbpxwnlbqgb.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=

# Unico IA (Gemini)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash-lite

# Stripe (fees reales / refund endpoint si lo usas después)
STRIPE_SECRET_KEY=sk_live_...

# Envía (solo para health-check en UnicOs; Score Store lo usa en Netlify Functions)
ENVIA_API_KEY=...

# FX (si Stripe devuelve fees en USD y quieres convertir a MXN)
FX_USD_TO_MXN=17.20